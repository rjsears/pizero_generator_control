# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=
# GenMaster Environment Configuration
# Version 1.0.0 - January 15th, 2026
#
# DO NOT edit this file directly!
# Run ./setup.sh to configure your installation.
#
# Richard J. Sears
# richardjsears@protonmail.com
# https://github.com/rjsears
# -=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=-=

# =============================================================================
# Domain Configuration
# =============================================================================
# Your domain name (e.g., genmaster.example.com)
DOMAIN=genmaster.example.com

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
APP_DEBUG=false
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# GenMaster Docker image version
GENMASTER_VERSION=latest

# Timezone
TIMEZONE=America/Los_Angeles

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
DATABASE_USER=genmaster
# Generate with: openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=genmaster
# DATABASE_HOST and DATABASE_PORT are set automatically by docker-compose

# =============================================================================
# Admin User (created on first run)
# =============================================================================
ADMIN_USERNAME=admin
# Generate with: openssl rand -base64 16 | tr -dc 'a-zA-Z0-9' | head -c 16
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# =============================================================================
# GenSlave Communication
# =============================================================================
# Use Tailscale hostname if using Tailscale, otherwise use IP/hostname
SLAVE_API_URL=http://genslave.local:8001
# Shared secret for authenticating with GenSlave
SLAVE_API_SECRET=CHANGE_ME_SHARED_SECRET_WITH_GENSLAVE

# =============================================================================
# Heartbeat Settings
# =============================================================================
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_FAILURE_THRESHOLD=3

# =============================================================================
# Webhook Notifications (Optional)
# =============================================================================
# URL for n8n or other webhook receiver
WEBHOOK_BASE_URL=
# HMAC secret for webhook signature verification
WEBHOOK_SECRET=

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Web Server Port
# =============================================================================
# Port for nginx to listen on (Cloudflare Tunnel connects here)
HTTP_PORT=80

# =============================================================================
# Cloudflare Tunnel (Required for HTTPS access)
# =============================================================================
# Create tunnel at: https://one.dash.cloudflare.com/ -> Access -> Tunnels
# Configure tunnel to point to http://localhost:80
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================================================
# Tailscale VPN (Optional - use with --profile tailscale)
# =============================================================================
# Generate auth key at: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=genmaster
TAILSCALE_EXTRA_ARGS=--advertise-tags=tag:generator
