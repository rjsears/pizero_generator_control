# GenMaster Environment Configuration
# Copy this file to .env and configure for your environment
#
# Generate secrets with: openssl rand -hex 32

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# GenMaster Docker image version
GENMASTER_VERSION=latest

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
DATABASE_USER=genmaster
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_NAME=genmaster
# DATABASE_HOST and DATABASE_PORT are set automatically by docker-compose

# =============================================================================
# GenSlave Communication
# =============================================================================
# Use Tailscale hostname if using Tailscale, otherwise use IP
SLAVE_API_URL=http://genslave:8000
SLAVE_API_SECRET=CHANGE_ME_SHARED_SECRET_WITH_GENSLAVE

# =============================================================================
# Heartbeat Settings
# =============================================================================
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_FAILURE_THRESHOLD=3

# =============================================================================
# Webhook Notifications (Optional)
# =============================================================================
# URL for n8n or other webhook receiver
# WEBHOOK_BASE_URL=http://n8n:5678/webhook/generator
# WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Web Server Ports
# =============================================================================
HTTP_PORT=80
HTTPS_PORT=443

# =============================================================================
# SSL Configuration
# Path to SSL certificates (mounted into nginx container)
# =============================================================================
SSL_CERT_PATH=./nginx/ssl

# =============================================================================
# Tailscale VPN (Optional - use with --profile tailscale)
# =============================================================================
# Generate auth key at: https://login.tailscale.com/admin/settings/keys
# TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxx
# TAILSCALE_EXTRA_ARGS=--advertise-tags=tag:generator

# =============================================================================
# Cloudflare Tunnel (Optional - use with --profile cloudflare)
# =============================================================================
# Create tunnel at: https://one.dash.cloudflare.com/ -> Access -> Tunnels
# CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxxxxxxxxx
